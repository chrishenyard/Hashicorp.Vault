{
  "SecretManager": {
    "Provider": "HashiCorpVault",
    "HashiCorpVault": {
      "Address": "https://vault.localhost",
      "AuthMethod": "AppRole",
      "RoleId": "",
      "SecretId": "",
      "MountPoint": "kv-v2",
      "SecretPath": "demo-app"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
