    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: pyvault CLI",
            "type": "debugpy",
            "request": "launch",
            "module": "pyvault.main",
            "args": ["delete", "--mount", "kv-v2", "--path", "demo-app"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        }
    ]
